generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("SISWA") // ADMIN or SISWA
  class     String?  // Kelas untuk siswa
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions    ExamSession[]
  answers     Answer[]
  createdExams Exam[]     @relation("ExamCreator")
}

model Exam {
  id          String   @id @default(cuid())
  title       String
  description String?
  duration    Int      @default(60) // Durasi dalam menit
  isActive    Boolean  @default(false)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   Question[]
  sessions    ExamSession[]

  creator     User     @relation("ExamCreator", fields: [createdBy], references: [id])
}

model Question {
  id             String   @id @default(cuid())
  examId         String
  questionText   String
  optionA        String
  optionB        String
  optionC        String
  optionD        String
  optionE        String
  correctAnswer  String   // A, B, C, D, or E
  explanation    String?  // Pembahasan jawaban
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers        Answer[]
}

model ExamSession {
  id        String   @id @default(cuid())
  userId    String
  examId    String
  startTime DateTime
  endTime   DateTime?
  status    String   @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, EXPIRED
  score     Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  exam      Exam     @relation(fields: [examId], references: [id])
  answers   Answer[]
}

model Answer {
  id              String   @id @default(cuid())
  sessionId       String
  questionId      String
  selectedAnswer  String?  // A, B, C, D, or E
  isCorrect       Boolean?
  createdAt       DateTime @default(now())

  session         ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question        Question   @relation(fields: [questionId], references: [id])
  user            User       @relation(fields: [userId], references: [id])
  userId          String
}
